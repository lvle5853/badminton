<view class="page">
  <view wx:if="{{hasFilter}}" class="active-filter-bar">
    <view class="active-filter-list">
      <view wx:for="{{selectedFilters}}" wx:key="id" class="active-filter-item {{item.genderClass}}">
        <text class="active-filter-name">{{item.name}}</text>
        <text class="active-filter-level">{{item.level}}</text>
      </view>
    </view>
    <button class="btn-secondary-sm" bindtap="clearPlayerFilter">显示全部</button>
  </view>

  <view wx:if="{{matches.length === 0}}" class="empty-state">
    <text>{{emptyText}}</text>
  </view>

  <block wx:for="{{matches}}" wx:key="index">
    <view class="match-card">
      <!-- Match Header -->
      <view class="match-head">
        <text class="match-num">第 {{item.num}} 场</text>
        <text class="match-meta">{{item.typeLabel}} · {{item.levelLabel}}</text>
      </view>

      <!-- Match Body -->
      <view class="match-body">
        <view class="team team-left">
          <view class="team-player {{item.genderClass}} {{item.selected ? 'is-selected' : ''}}"
            wx:for="{{item.teamA}}" wx:key="id" data-id="{{item.id}}" bindtap="togglePlayerFilter">
            <text class="team-name">{{item.name}}</text>
            <text class="team-level">{{item.level}}</text>
          </view>
        </view>
        <text class="versus">VS</text>
        <view class="team team-right">
          <view class="team-player {{item.genderClass}} {{item.selected ? 'is-selected' : ''}}"
            wx:for="{{item.teamB}}" wx:key="id" data-id="{{item.id}}" bindtap="togglePlayerFilter">
            <text class="team-name">{{item.name}}</text>
            <text class="team-level">{{item.level}}</text>
          </view>
        </view>
      </view>

      <!-- Score Row -->
      <view class="score-row">
        <input class="score-input" type="number" placeholder="左队"
          value="{{item.scoreA}}" data-index="{{item.index}}" data-side="a"
          bindinput="onScoreInput" bindblur="onScoreBlur" />
        <input class="score-input" type="number" placeholder="右队"
          value="{{item.scoreB}}" data-index="{{item.index}}" data-side="b"
          bindinput="onScoreInput" bindblur="onScoreBlur" />
        <button class="btn-clear" data-index="{{item.index}}" bindtap="clearScore">清空</button>
      </view>
    </view>
  </block>

  <view wx:if="{{matches.length > 0}}" class="action-bar">
    <button class="btn-primary" bindtap="goToRanking">查看排名</button>
  </view>

  <view wx:if="{{note}}" class="note">{{note}}</view>
</view>
