.page {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.active-filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.active-filter-list {
  flex: 1;
  min-width: 0;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.active-filter-item,
.team-player {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
  max-width: 150rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid transparent;
  border-radius: 12rpx;
}

.active-filter-name,
.team-name {
  color: #1d2824;
  font-size: 28rpx;
  font-weight: 800;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.active-filter-level,
.team-level {
  color: #64716c;
  font-size: 20rpx;
  white-space: nowrap;
}

.match-card {
  background: #ffffff;
  border: 1rpx solid #d9dfda;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.match-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fbfcfa;
  border-bottom: 1rpx solid #d9dfda;
  gap: 12rpx;
}

.match-num {
  color: #1d2824;
  font-size: 26rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.match-meta {
  color: #64716c;
  font-size: 24rpx;
  font-weight: 700;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.match-body {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.team {
  flex: 1;
  min-width: 0;
  display: flex;
  gap: 12rpx;
}

.team-left {
  justify-content: flex-end;
  text-align: center;
}

.team-right {
  justify-content: flex-start;
  text-align: center;
}

.gender-male {
  background: #e8f2ff;
  border-color: #c6e2ff;
}

.gender-female {
  background: #ffeaf3;
  border-color: #ffc9dc;
}

.team-player.is-selected {
  border-color: #1d7fbd;
  box-shadow: 0 0 0 4rpx rgba(29, 127, 189, 0.12);
}

.versus {
  color: #b78103;
  font-weight: 900;
  font-size: 28rpx;
  flex-shrink: 0;
}

.score-row {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx 20rpx;
  align-items: center;
}

.score-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #d9dfda;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  background: #fff;
}

.btn-clear {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  background: #f3eeee;
  color: #b42318;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-clear::after {
  border: none;
}

.btn-secondary-sm {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: #f3eeee;
  color: #b42318;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-secondary-sm::after {
  border: none;
}

.action-bar {
  margin-top: 16rpx;
}

.note {
  margin-top: 20rpx;
  color: #64716c;
  font-size: 24rpx;
  text-align: center;
}
